# EC2에 .env.prod 파일로 복사 후 실제 값으로 채우세요
# 이 파일은 예시용이며 git에 올라갑니다

# PostgreSQL
POSTGRES_USER=palantiny
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=palantiny_db

# 관리자 계정
ADMIN_ID=admin
ADMIN_PASSWORD=your_admin_password_here

# JWT
JWT_SECRET=your_random_secret_key_here
JWT_EXPIRE_HOURS=24

# CORS (프론트엔드 도메인, 예: https://example.com)
ALLOWED_ORIGINS=https://your-cloudfront-domain.cloudfront.net

# Neo4j AuraDB
NEO4J_URI=neo4j+s://your-aura-instance.databases.neo4j.io
NEO4J_USERNAME=your-instance-id
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=your-instance-id
